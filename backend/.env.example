# PKY AI Assistant Backend Configuration
# ──────────────────────────────────────────────────────────
# HOW TO SETUP:
# 1. Copy this file:  cp .env.example .env
# 2. Set OPENROUTER_API_KEY (get your free key at https://openrouter.ai)
# 3. Run: uvicorn main:app --reload
# ──────────────────────────────────────────────────────────

# ┌──────────────────────────────────────────────────────────┐
# │  OPENROUTER API KEY  (REQUIRED — get free at openrouter.ai)│
# └──────────────────────────────────────────────────────────┘
OPENROUTER_API_KEY="sk-or-v1-your-key-here"

# ──────────────────────────────────────────────────────────
# TOP 10 OPENROUTER FREE MODELS — choose any in PKY AI Assistant UI
# ──────────────────────────────────────────────────────────
#
#  #  MODEL ID                                     BEST FOR
#  1  meta-llama/llama-3.3-70b-instruct:free       General Chat (GPT-4 level)
#  2  qwen/qwen3-coder:free                        Code Generation (262K ctx)
#  3  google/gemini-2.0-flash-exp:free             Supervisor / Fast Routing (1M ctx)
#  4  deepseek/deepseek-r1:free                    Deep Reasoning / Analysis
#  5  nvidia/nemotron-3-super:free                 Long Documents / RAG (262K ctx)
#  6  stepfun/step-3.5-flash:free                  Extended Thinking
#  7  openai/gpt-oss-120b:free                     Planning / Architecture
#  8  nvidia/nemotron-3-nano-30b-a3b:free          Agentic Workflows
#  9  moonshotai/kimi-k2.5:free                    Long Sessions (128K ctx)
#  10 qwen/qwen3-next-80b:free                     RAG & Tool Use
#
# NOTE: All models above are FREE. Rate limit: 20 req/min, 200 req/day.
#       Add OpenRouter credits for higher throughput.
#
# Set the default model for each brain below:
PKY_DEFAULT_MODEL="meta-llama/llama-3.3-70b-instruct:free"
PKY_CODING_MODEL="qwen/qwen3-coder:free"
PKY_SUPERVISOR_MODEL="google/gemini-2.0-flash-exp:free"
PKY_REASONING_MODEL="deepseek/deepseek-r1:free"
PKY_DOCUMENT_MODEL="nvidia/nemotron-3-super:free"
PKY_PLANNING_MODEL="openai/gpt-oss-120b:free"

# ──────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ──────────────────────────────────────────────────────────
PKY_AI_APP_NAME="PKY AI Assistant"
PKY_AI_VERSION="1.0.0"
PKY_AI_DEBUG=false

# Security — CHANGE THIS! Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
PKY_AI_SECRET_KEY="change-me-to-a-random-secret-in-production"
PKY_AI_ALGORITHM="HS256"
PKY_AI_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin account — REQUIRED. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(18))"
# If unset, a random password is auto-generated and printed to logs on first startup.
PKY_AI_ADMIN_PASSWORD="change-me-in-production"

# CORS — add your frontend URL
PKY_AI_CORS_ORIGINS='["http://localhost:3000", "http://localhost:8080"]'
PKY_AI_CORS_CREDENTIALS=true

# Rate Limiting
PKY_AI_RATE_LIMIT_REQUESTS=10
PKY_AI_RATE_LIMIT_WINDOW=60

# ──────────────────────────────────────────────────────────
# DATA STORAGE
# ──────────────────────────────────────────────────────────
PKY_AI_DATA_DIR="data"
# REQUIRED — Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PKY_AI_ENCRYPTION_KEY="change-me-to-a-random-key-in-production"

# Database (PostgreSQL — for persistent memory)
DATABASE_URL="postgresql+asyncpg://pky_ai_user:pky_ai_password@localhost:5432/pky_ai"

# Redis (for conversation history caching)
PKY_AI_REDIS_URL="redis://localhost:6379/0"
REDIS_URL="redis://localhost:6379/0"

# ──────────────────────────────────────────────────────────
# VOICE ENGINE (OPTIONAL)
# ──────────────────────────────────────────────────────────
PKY_AI_WHISPER_MODEL="small"      # Options: tiny, base, small, medium, large
PKY_AI_WHISPER_DEVICE="cpu"       # Options: cpu, cuda
PKY_AI_TTS_MODEL="tts_models/en/ljspeech/tacotron2-DDC"
PKY_AI_TTS_DEVICE="cpu"           # Options: cpu, cuda

# Timeouts (seconds)
PKY_AI_WHISPER_TIMEOUT=30
PKY_AI_TTS_TIMEOUT=15
PKY_AI_RSS_FETCH_TIMEOUT=10
PKY_AI_WEBSOCKET_RECEIVE_TIMEOUT=30

# ──────────────────────────────────────────────────────────
# FEATURE FLAGS
# ──────────────────────────────────────────────────────────
PKY_AI_USE_LOCAL_LLM=false            # Set true to use a local GGUF model
LOCAL_MODEL_PATH="models/your-model.gguf"
PKY_AI_ENABLE_VOICE_CLONING=false
PKY_AI_ENABLE_DAILY_REPORTS=true
PKY_AI_ENABLE_SELF_CORRECTION=true
PKY_AI_ENABLE_JOB_SERVICE=false      # Set true only when browser automation is tested

# ──────────────────────────────────────────────────────────
# OPTIONAL EXTERNAL API KEYS
# ──────────────────────────────────────────────────────────
NEWS_API_KEY=""        # https://newsapi.org — for news features
OPENAI_API_KEY=""      # Optional — if you want to use OpenAI directly

# ──────────────────────────────────────────────────────────
# GRAPH MEMORY (OPTIONAL — Phase 10)
# ──────────────────────────────────────────────────────────
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
# REQUIRED if Neo4j is used — if unset, graph memory is gracefully disabled
NEO4J_PASSWORD="your-neo4j-password-here"

# ──────────────────────────────────────────────────────────
# PHASE 1: LIVEKIT WEBRTC VOICE TRANSPORT
# ──────────────────────────────────────────────────────────
# Get free LiveKit Cloud at https://cloud.livekit.io
# Or self-host: docker run -d -p 7880:7880 livekit/livekit-server
LIVEKIT_URL="ws://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="secret"

# ──────────────────────────────────────────────────────────
# PHASE 1: TTS ENGINE SELECTION
# ──────────────────────────────────────────────────────────
# kokoro  = Dual-streaming on-device ~180ms FTTS (RECOMMENDED)
#           Install: pip install kokoro>=0.3.4 soundfile
# coqui   = Local neural TTS (needs GPU for real-time speed)
# gtts    = Cloud Google TTS (simple fallback, needs internet)
PKY_AI_TTS_ENGINE="kokoro"

# ──────────────────────────────────────────────────────────
# PHASE 6: MULTIMODAL (CAMERA + FILE UPLOAD)
# ──────────────────────────────────────────────────────────
PKY_AI_ENABLE_MULTIMODAL=true
PKY_AI_MAX_UPLOAD_SIZE_MB=10